# ─────────────────────────────────────────────────────────────
#  Environment variables — copy this file to .env and fill in
#  the values before running the server.
#
#  NEVER commit your real .env file to Git!
# ─────────────────────────────────────────────────────────────

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────
# 1. Go to https://developers.facebook.com/
# 2. Create an App → Business type → Add WhatsApp product
# 3. Under WhatsApp > API Setup you will find:
#    - "Temporary access token" (use System User token for production)
#    - "Phone number ID"

WHATSAPP_TOKEN=PASTE_YOUR_META_ACCESS_TOKEN_HERE
WHATSAPP_PHONE_ID=PASTE_YOUR_PHONE_NUMBER_ID_HERE

# ── Webhook verification ──────────────────────────────────────
# Any secret string you choose — you will paste this same string
# into the Meta webhook setup page under "Verify token"

VERIFY_TOKEN=ESCOLHA_UMA_STRING_SECRETA_AQUI

# App Secret do Meta (Settings → Basic → App Secret).
# Usado pra validar a assinatura HMAC dos webhooks (X-Hub-Signature-256).
# Sem isso, qualquer um pode mandar payload falso pro /webhook.
APP_SECRET=PASTE_YOUR_META_APP_SECRET_HERE

# ── Anthropic Claude API ──────────────────────────────────────
# Get your key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-PASTE_YOUR_KEY_HERE

# ── Business settings ─────────────────────────────────────────
# The scheduling link sent to customers when they ask to book

BOOKING_LINK=https://link-do-app

# ── Notificações ─────────────────────────────────────────────
# Número que recebe alerta quando cliente pede atendente humano
BARBERSHOP_PHONE=55XXXXXXXXXXX

# Número que recebe o relatório diário às 22h (horário de SP)
OWNER_PHONE=55XXXXXXXXXXX

# ── Painel /admin ────────────────────────────────────────────
# Senha pra acessar o painel web em https://.../admin
# (usuário pode ser qualquer coisa, só a senha é validada)
ADMIN_PASSWORD=trocar_essa_senha

# ── Alertas ──────────────────────────────────────────────────
# Alertas críticos (crash, token expirado, IA fora) vão pro OWNER_PHONE
# automaticamente. Cooldown de 5min por tipo de erro evita spam.
# Para receber notificação a cada startup do servidor, descomente:
# STARTUP_ALERT=true

# ── Follow-up automático ─────────────────────────────────────
# Após N minutos sem resposta do cliente, manda mensagem contextual
# ("conseguiu agendar?", "precisa de algo mais?")
# Padrão: 30. Defina FOLLOWUP_ENABLED=false para desativar.
FOLLOWUP_DELAY_MIN=30
# FOLLOWUP_ENABLED=false

# ── Persistência ─────────────────────────────────────────────
# Diretório para salvar faq.json e conversations.json.
# No Railway: monte um Volume em /data e defina DATA_DIR=/data
# Sem isso, os arquivos vivem na raiz do projeto e são perdidos a cada deploy.
DATA_DIR=/data

# ── Server ────────────────────────────────────────────────────
# Railway sets PORT automatically; leave as 3000 for local dev

PORT=3000
